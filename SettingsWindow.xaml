<Window x:Class="NumpadOverlay.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Overlay Settings"
        SizeToContent="Height"
        Width="360"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="#FF151827"
        Foreground="#F3F5FF"
        FontFamily="Segoe UI"
        FontSize="14"
        WindowStyle="ToolWindow">
    <Border Background="#FF1B1E33" CornerRadius="14" Padding="18" Margin="10">
        <StackPanel Orientation="Vertical" Spacing="14">
            <TextBlock Text="Overlay Settings" FontSize="20" FontWeight="Bold" />

            <StackPanel Orientation="Vertical" Spacing="8">
                <TextBlock Text="Opacity" FontWeight="SemiBold" />
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="10">
                    <Slider x:Name="OpacitySlider"
                            Minimum="0.1"
                            Maximum="1.0"
                            Value="{Binding Opacity, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                            TickFrequency="0.05"
                            IsSnapToTickEnabled="False"
                            Width="210" />
                    <TextBlock Text="{Binding Opacity, StringFormat={}{0:P0}}"
                               VerticalAlignment="Center"
                               Width="40"
                               TextAlignment="Center"
                               FontWeight="SemiBold" />
                </StackPanel>
            </StackPanel>

            <StackPanel Orientation="Vertical" Spacing="8">
                <TextBlock Text="Size" FontWeight="SemiBold" />
                <UniformGrid Columns="3" Rows="1" ColumnSpacing="10">
                    <RadioButton x:Name="SmallSizeRadio" Content="Small" Tag="Small" Checked="SizeRadio_Checked" />
                    <RadioButton x:Name="MediumSizeRadio" Content="Medium" Tag="Medium" Checked="SizeRadio_Checked" />
                    <RadioButton x:Name="LargeSizeRadio" Content="Large" Tag="Large" Checked="SizeRadio_Checked" />
                </UniformGrid>
            </StackPanel>

            <StackPanel Orientation="Vertical" Spacing="8">
                <TextBlock Text="Toggle Hotkey" FontWeight="SemiBold" />
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="8">
                    <TextBlock Text="Ctrl +" FontFamily="Consolas" FontSize="16" VerticalAlignment="Center" />
                    <ComboBox x:Name="HotkeyKeyCombo"
                              Width="160"
                              SelectionChanged="HotkeyKeyCombo_SelectionChanged"
                              FontFamily="Consolas"
                              FontSize="16">
                        <ComboBoxItem Tag="0xC0">`</ComboBoxItem>
                        <ComboBoxItem Tag="0x70">F1</ComboBoxItem>
                        <ComboBoxItem Tag="0x71">F2</ComboBoxItem>
                        <ComboBoxItem Tag="0x72">F3</ComboBoxItem>
                        <ComboBoxItem Tag="0x73">F4</ComboBoxItem>
                        <ComboBoxItem Tag="0x74">F5</ComboBoxItem>
                        <ComboBoxItem Tag="0x75">F6</ComboBoxItem>
                        <ComboBoxItem Tag="0x76">F7</ComboBoxItem>
                        <ComboBoxItem Tag="0x77">F8</ComboBoxItem>
                        <ComboBoxItem Tag="0x78">F9</ComboBoxItem>
                        <ComboBoxItem Tag="0x79">F10</ComboBoxItem>
                        <ComboBoxItem Tag="0x7A">F11</ComboBoxItem>
                        <ComboBoxItem Tag="0x7B">F12</ComboBoxItem>
                    </ComboBox>
                </StackPanel>
            </StackPanel>

            <Border Background="#FF222742" CornerRadius="10" Padding="14" Margin="0,4,0,0">
                <StackPanel Orientation="Vertical" Spacing="6">
                    <TextBlock Text="Note" FontWeight="SemiBold" />
                    <TextBlock Text="Các thay đổi sẽ được giữ lại khi bạn đóng cửa sổ cài đặt." TextWrapping="Wrap" Opacity="0.8" />
                </StackPanel>
            </Border>

            <Button Content="Exit Application"
                    Click="ExitButton_Click"
                    Background="#FFE94560"
                    Foreground="White"
                    Padding="10"
                    FontWeight="Bold"
                    BorderThickness="0"
                    Cursor="Hand"
                    HorizontalAlignment="Stretch" />
        </StackPanel>
    </Border>
</Window>
