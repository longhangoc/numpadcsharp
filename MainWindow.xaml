<Window x:Class="NumpadOverlay.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Bàn phím số ảo"
        Width="380"
        Height="510"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        Opacity="0.85"
        MouseDown="Window_MouseDown">
    <Border x:Name="RootBorder"
            Background="#DD1A1A2E"
            CornerRadius="16"
            Padding="16"
            Margin="8">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="12" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Bàn phím số ảo"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="#F3F5FF"
                               VerticalAlignment="Center" />
                    <Border x:Name="NumLockStatusBorder"
                            Background="#FF16213E"
                            CornerRadius="8"
                            Padding="6,3"
                            VerticalAlignment="Center"
                            Margin="10,0,0,0">
                        <TextBlock x:Name="NumLockStatusText"
                                   Text="NumLock: TẮT"
                                   Foreground="#F3F5FF"
                                   FontFamily="Consolas"
                                   FontSize="12"
                                   VerticalAlignment="Center" />
                    </Border>
                </StackPanel>

                <Button x:Name="SettingsButton"
                        Grid.Column="1"
                        Content="⚙"
                        Width="32"
                        Height="32"
                        FontSize="16"
                        Background="#FF16213E"
                        Foreground="#F3F5FF"
                        BorderThickness="0"
                        Cursor="Hand"
                        Click="SettingsButton_Click" />
            </Grid>

            <Grid Grid.Row="2"
                  Margin="0,8,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border x:Name="NumLockKey" Grid.Row="0" Grid.Column="0" Background="#FF16213E" CornerRadius="10" Padding="12" IsHitTestVisible="False" Opacity="0.95">
                    <TextBlock Text="NumLock" Foreground="#F3F5FF" FontFamily="Consolas" HorizontalAlignment="Center" VerticalAlignment="Center" TextAlignment="Center"/>
                </Border>
                <Border x:Name="DivideKey" Grid.Row="0" Grid.Column="1" Background="#FF16213E" CornerRadius="10" Padding="12" IsHitTestVisible="False" Opacity="0.95">
                    <TextBlock Text="/" Foreground="#F3F5FF" FontFamily="Consolas" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
                <Border x:Name="MultiplyKey" Grid.Row="0" Grid.Column="2" Background="#FF16213E" CornerRadius="10" Padding="12" IsHitTestVisible="False" Opacity="0.95">
                    <TextBlock Text="*" Foreground="#F3F5FF" FontFamily="Consolas" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
                <Border x:Name="BackspaceKey" Grid.Row="0" Grid.Column="3" Background="#FF16213E" CornerRadius="10" Padding="12" IsHitTestVisible="False" Opacity="0.95">
                    <TextBlock Text="Back" Foreground="#F3F5FF" FontFamily="Consolas" HorizontalAlignment="Center" VerticalAlignment="Center" TextAlignment="Center"/>
                </Border>

                <Border x:Name="Key7" Grid.Row="1" Grid.Column="0" Background="#FF16213E" CornerRadius="10" Padding="18" IsHitTestVisible="False" Opacity="0.95">
                    <TextBlock Text="7" Foreground="#F3F5FF" FontFamily="Consolas" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
                <Border x:Name="Key8" Grid.Row="1" Grid.Column="1" Background="#FF16213E" CornerRadius="10" Padding="18" IsHitTestVisible="False" Opacity="0.95">
                    <TextBlock Text="8" Foreground="#F3F5FF" FontFamily="Consolas" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
                <Border x:Name="Key9" Grid.Row="1" Grid.Column="2" Background="#FF16213E" CornerRadius="10" Padding="18" IsHitTestVisible="False" Opacity="0.95">
                    <TextBlock Text="9" Foreground="#F3F5FF" FontFamily="Consolas" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
                <Border x:Name="SubtractKey" Grid.Row="1" Grid.Column="3" Background="#FF16213E" CornerRadius="10" Padding="18" IsHitTestVisible="False" Opacity="0.95">
                    <TextBlock Text="-" Foreground="#F3F5FF" FontFamily="Consolas" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>

                <Border x:Name="Key4" Grid.Row="2" Grid.Column="0" Background="#FF16213E" CornerRadius="10" Padding="18" IsHitTestVisible="False" Opacity="0.95">
                    <TextBlock Text="4" Foreground="#F3F5FF" FontFamily="Consolas" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
                <Border x:Name="Key5" Grid.Row="2" Grid.Column="1" Background="#FF16213E" CornerRadius="10" Padding="18" IsHitTestVisible="False" Opacity="0.95">
                    <TextBlock Text="5" Foreground="#F3F5FF" FontFamily="Consolas" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
                <Border x:Name="Key6" Grid.Row="2" Grid.Column="2" Background="#FF16213E" CornerRadius="10" Padding="18" IsHitTestVisible="False" Opacity="0.95">
                    <TextBlock Text="6" Foreground="#F3F5FF" FontFamily="Consolas" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
                <Border x:Name="AddKey" Grid.Row="2" Grid.Column="3" Background="#FF16213E" CornerRadius="10" Padding="18" IsHitTestVisible="False" Opacity="0.95">
                    <TextBlock Text="+" Foreground="#F3F5FF" FontFamily="Consolas" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>

                <Border x:Name="Key1" Grid.Row="3" Grid.Column="0" Background="#FF16213E" CornerRadius="10" Padding="18" IsHitTestVisible="False" Opacity="0.95">
                    <TextBlock Text="1" Foreground="#F3F5FF" FontFamily="Consolas" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
                <Border x:Name="Key2" Grid.Row="3" Grid.Column="1" Background="#FF16213E" CornerRadius="10" Padding="18" IsHitTestVisible="False" Opacity="0.95">
                    <TextBlock Text="2" Foreground="#F3F5FF" FontFamily="Consolas" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
                <Border x:Name="Key3" Grid.Row="3" Grid.Column="2" Background="#FF16213E" CornerRadius="10" Padding="18" IsHitTestVisible="False" Opacity="0.95">
                    <TextBlock Text="3" Foreground="#F3F5FF" FontFamily="Consolas" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
                <Border x:Name="EnterKey" Grid.Row="3" Grid.Column="3" Grid.RowSpan="2" Background="#FF16213E" CornerRadius="10" Padding="18" IsHitTestVisible="False" Opacity="0.95">
                    <TextBlock Text="Enter" Foreground="#F3F5FF" FontFamily="Consolas" HorizontalAlignment="Center" VerticalAlignment="Center" TextAlignment="Center"/>
                </Border>

                <Border x:Name="ZeroKey" Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2" Background="#FF16213E" CornerRadius="10" Padding="18" IsHitTestVisible="False" Opacity="0.95">
                    <TextBlock Text="0" Foreground="#F3F5FF" FontFamily="Consolas" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
                <Border x:Name="DecimalKey" Grid.Row="4" Grid.Column="2" Background="#FF16213E" CornerRadius="10" Padding="18" IsHitTestVisible="False" Opacity="0.95">
                    <TextBlock Text="." Foreground="#F3F5FF" FontFamily="Consolas" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>
