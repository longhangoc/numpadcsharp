<Window x:Class="NumpadOverlay.UpdateWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cập nhật OpenNP"
        Width="400" Height="340"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent" WindowStartupLocation="CenterScreen"
        Topmost="True">
    <Border Background="#DD1A1A2E" CornerRadius="16" Padding="20">
        <StackPanel>
            <TextBlock Text="Cập nhật phần mềm" FontSize="18" FontWeight="Bold" Foreground="#F3F5FF" />
            <TextBlock x:Name="VersionText" Text="Phiên bản hiện tại: 1.0.0 → 1.1.0" Margin="0,12,0,0" Foreground="#F3F5FF" />
            
            <TextBlock Text="Changelog:" FontWeight="SemiBold" Margin="0,12,0,4" Foreground="#F3F5FF" />
            <ScrollViewer Height="100" Margin="0,0,0,8">
                <TextBlock x:Name="ChangelogText" TextWrapping="Wrap" Foreground="#F3F5FF" FontSize="11" />
            </ScrollViewer>
            
            <ProgressBar x:Name="DownloadProgress" Minimum="0" Maximum="100" Value="0" Height="8" Margin="0,20,0,8" Background="#FF16213E" Foreground="#E94560" />
            <TextBlock x:Name="StatusText" Text="Đang tải..." Foreground="#F3F5FF" FontSize="12" />

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                <Button Content="Hủy" Width="80" Height="32" Background="#FF16213E" Foreground="#F3F5FF" BorderThickness="0" Click="Cancel_Click" />
                <Button x:Name="UpdateButton" Content="Cập nhật" Width="80" Height="32" Background="#E94560" Foreground="White" BorderThickness="0" Margin="12,0,0,0" Click="Update_Click" />
            </StackPanel>
        </StackPanel>
    </Border>
</Window>